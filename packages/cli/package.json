{
  "name": "speedtest-cli",
  "version": "1.0.0",
  "description": "CLI tool for running internet speed tests",
  "homepage": "https://github.com/Yac0z/speed-test-app",
  "bugs": {
    "url": "https://github.com/Yac0z/speed-test-app/issues"
  },
  "license": "MIT",
  "author": "Yacin",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yac0z/speed-test-app.git"
  },
  "bin": {
    "speedtest-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const esbuild=require('esbuild'); esbuild.buildSync({entryPoints:['src/index.ts'],bundle:true,platform:'node',outfile:'dist/index.js',format:'cjs',external:['speedtest-core']});\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "pkg": "npm run build && pkg dist/index.js --targets latest-win-x64,latest-linux-x64,latest-macos-x64 --out-path dist-bin",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cloudflare/speedtest": "^1.7.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "speedtest-core": "file:../core"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
