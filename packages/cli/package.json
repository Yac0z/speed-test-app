{
  "name": "@speedtest/cli",
  "version": "1.0.0",
  "description": "CLI tool for running internet speed tests",
  "bin": {
    "speedtest-cli": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "pkg": "pkg . --targets node20-win-x64,node20-linux-x64,node20-macos-x64 --out-path dist-bin",
    "test": "vitest run"
  },
  "dependencies": {
    "@speedtest/core": "file:../core",
    "commander": "^12.0.0",
    "cli-table3": "^0.6.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "pkg": "^5.8.1",
    "vitest": "^3.1.4"
  }
}
