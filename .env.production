# Hosting
# Replace by your domain name
NEXT_PUBLIC_APP_URL=https://speed-test-app.vercel.app

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=info

# Arcjet security
# Get your key from https://launch.arcjet.com/Q6eLbRE
# ARCJET_KEY=

# Database
# Using an incorrect DATABASE_URL value, Next.js build will timeout
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Error monitoring
# SENTRY_AUTH_TOKEN=
# SENTRY_ORGANIZATION=
# SENTRY_PROJECT=
# NEXT_PUBLIC_SENTRY_DSN=
